# ------------------------------------------------------------------
# HardcoreRP – zentrale Umgebungskonfiguration
# Kopieren nach .env und ALLE Secrets ersetzen. Niemals .env committen.
# ------------------------------------------------------------------

# --- Allgemein ---
DOMAIN=rp.example.com
TZ=Europe/Berlin

# --- MariaDB (Spiel-Datenbank) ---
MARIADB_ROOT_PASSWORD=change-me-root
MARIADB_DATABASE=hrp_game
MARIADB_USER=hrp
MARIADB_PASSWORD=change-me-db

# --- TimescaleDB (Log-/Analytics-Store, getrennt von der Spiel-DB) ---
LOGSTORE_DB=hrp_logs
LOGSTORE_USER=hrp_logs
LOGSTORE_PASSWORD=change-me-logs

# --- Redis (Cache, Sessions, Streams als Message-Queue) ---
REDIS_PASSWORD=change-me-redis

# --- Backend (NestJS) ---
BACKEND_PORT=3001
# Shared Secret Gameserver -> Backend-Ingest (nur internes Docker-Netz!)
INGEST_TOKEN=change-me-long-random-token

# --- Log-Retention (Tage, DSGVO-Löschkonzept; 0 = nie) ---
LOG_RETENTION_DAYS=90
POSITION_RETENTION_DAYS=30

# --- FiveM ---
FIVEM_LICENSE_KEY=cfxk_change_me
FIVEM_SERVER_NAME=HardcoreRP
FIVEM_MAX_CLIENTS=128
FIVEM_GAME_BUILD=3095

# --- Backups ---
BACKUP_DIR=/backups
BACKUP_FULL_CRON=0 4 * * *
BACKUP_INCR_CRON=0 * * * *
